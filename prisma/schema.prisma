generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Role: PROSPECT | ADMIN
// AuthProvider: EMAIL | GOOGLE
// ProspectIntent: finding_advisor | evaluating_existing_advisor
// ProspectStatus: ACTIVE | COMPLETED
// EvaluationStatus: ACTIVE | COMPLETED | CONVERTED
// RfpStatus: DRAFT | OPEN | CLOSED
// InvitationStatus: SENT | OPENED | SUBMITTED | REVISION_REQUESTED
// ResponseStatus: SUBMITTED | PUBLISHED
// PaymentStatus: UNPAID | PAID
// RevisionStatus: PENDING | VIEWED | REVISED | EXPIRED

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  fullName     String
  role         String   @default("PROSPECT") // PROSPECT | ADMIN | ADVISOR
  authProvider String   @default("EMAIL") // EMAIL | GOOGLE
  googleSub    String?
  createdAt    DateTime @default(now())
  prospects    Prospect[]
  advisor      Advisor?
}

model Prospect {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  assetsRange String
  primaryGoal String
  intent      String   @default("finding_advisor") // finding_advisor | evaluating_existing_advisor
  status      String   @default("ACTIVE") // ACTIVE | COMPLETED
  createdAt   DateTime @default(now())
  profile     ProspectProfile?
  rfps        Rfp[]
  evaluations AdvisorEvaluation[]
}

model ProspectProfile {
  id                        String  @id @default(cuid())
  prospectId                String  @unique
  prospect                  Prospect @relation(fields: [prospectId], references: [id])
  isBusinessOwner           Boolean @default(false)
  hasConcentratedStock      Boolean @default(false)
  wantsPrivateMarkets       Boolean @default(false)
  wantsLendingSolutions     Boolean @default(false)
  needsTaxCoordination      Boolean @default(false)
  servicePreference         String  @default("full-service") // full-service | self-directed | hybrid
  investmentStylePreference String  @default("moderate") // conservative | moderate | aggressive
  summaryText               String?
}

model Rfp {
  id                String   @id @default(cuid())
  prospectId        String
  prospect          Prospect @relation(fields: [prospectId], references: [id])
  title             String
  status            String   @default("OPEN") // DRAFT | OPEN | CLOSED
  questions         String   @default("[]") // JSON array of RFP questions
  freeResponseLimit Int      @default(3)
  paidUnlockPrice   Int      @default(499)
  createdAt         DateTime @default(now())
  invitations       RfpInvitation[]
  responses         AdvisorResponse[]
  comparisonView    ComparisonView?
  revisionRequests  RevisionRequest[]
  sourceEvaluation  AdvisorEvaluation?
}

model Advisor {
  id              String   @id @default(cuid())
  userId          String?  @unique
  user            User?    @relation(fields: [userId], references: [id])
  firmName        String
  leadAdvisorName String
  email           String
  firmType        String
  city            String
  clientMinimum   String
  bio             String?
  servicesOffered String?  // JSON array of service tags
  crdNumber       String?
  brokerCheckVerified Boolean @default(false)
  brokerCheckData String?  // JSON: name, firm, disclosures from BrokerCheck
  isPublic        Boolean  @default(true)
  createdAt       DateTime @default(now())
  invitations     RfpInvitation[]
  responses       AdvisorResponse[]
  revisionRequests RevisionRequest[]
}

model RfpInvitation {
  id          String   @id @default(cuid())
  rfpId       String
  rfp         Rfp      @relation(fields: [rfpId], references: [id])
  advisorId   String
  advisor     Advisor  @relation(fields: [advisorId], references: [id])
  inviteToken String   @unique
  status      String   @default("SENT") // SENT | OPENED | SUBMITTED | REVISION_REQUESTED
  responses   AdvisorResponse[]
  revisionRequests RevisionRequest[]
}

model AdvisorResponse {
  id                   String   @id @default(cuid())
  rfpId                String
  rfp                  Rfp      @relation(fields: [rfpId], references: [id])
  advisorId            String
  advisor              Advisor  @relation(fields: [advisorId], references: [id])
  invitationId         String
  invitation           RfpInvitation @relation(fields: [invitationId], references: [id])
  aumFeeBps            Int
  estimatedAnnualCost  Float
  lendingSpreadBps     Int?
  privateMarketsAccess String?
  clientsPerAdvisor    Int
  taxCoordinationLevel String
  differentiationText  String
  concessionsText      String?
  normalizedData       String?  // JSON: normalized extraction from free-form fields
  status               String   @default("SUBMITTED") // SUBMITTED | PUBLISHED
  createdAt            DateTime @default(now())

  // Versioning
  version              Int      @default(1)
  isLatest             Boolean  @default(true)
  previousResponseId   String?  @unique
  previousResponse     AdvisorResponse? @relation("ResponseChain", fields: [previousResponseId], references: [id])
  nextResponse         AdvisorResponse? @relation("ResponseChain")
  revisionRequestId    String?
  revisionRequest      RevisionRequest? @relation(fields: [revisionRequestId], references: [id])

  @@index([rfpId, advisorId, isLatest])
  @@index([invitationId, isLatest])
}

model RevisionRequest {
  id                 String   @id @default(cuid())
  createdAt          DateTime @default(now())
  rfpId              String
  rfp                Rfp      @relation(fields: [rfpId], references: [id])
  advisorId          String
  advisor            Advisor  @relation(fields: [advisorId], references: [id])
  invitationId       String
  invitation         RfpInvitation @relation(fields: [invitationId], references: [id])
  revisionToken      String   @unique
  aiGeneratedNote    String
  clientEditedNote   String?
  finalNote          String
  competitiveContext String   // JSON: snapshot of competitor data fed to AI
  status             String   @default("PENDING") // PENDING | VIEWED | REVISED | EXPIRED
  expiresAt          DateTime?
  responses          AdvisorResponse[]

  @@index([revisionToken])
  @@index([invitationId])
}

model ComparisonView {
  id                   String   @id @default(cuid())
  rfpId                String   @unique
  rfp                  Rfp      @relation(fields: [rfpId], references: [id])
  prospectId           String
  visibleResponseCount Int      @default(3)
  isPaywalled          Boolean  @default(true)
  paymentStatus        String   @default("UNPAID") // UNPAID | PAID
}

model AdvisorEvaluation {
  id                     String   @id @default(cuid())
  prospectId             String
  prospect               Prospect @relation(fields: [prospectId], references: [id])
  status                 String   @default("ACTIVE") // ACTIVE | COMPLETED | CONVERTED
  advisoryFeeBps         String?  // JSON: ConfidenceField
  lendingSpreadBps       String?  // JSON: ConfidenceField
  serviceModel           String?  // JSON: ConfidenceField
  portfolioCustomization String?  // JSON: ConfidenceField
  benchmarkResults       String?  // JSON: BenchmarkResult[]
  aiInsights             String?  // JSON: string[]
  convertedRfpId         String?  @unique
  convertedRfp           Rfp?     @relation(fields: [convertedRfpId], references: [id])
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([prospectId])
}
